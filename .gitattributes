# Normalisation — LF dans le dépôt (WSL2 / Linux / Mac)
* text=auto eol=lf

# Markdown
*.md text eol=lf

# Python
*.py text eol=lf

# Mermaid
*.mermaid text eol=lf

# Config / données
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.txt text eol=lf
.env* text eol=lf

# Binaires
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
